<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<title>Hockey Peak Plan</title>
<style>
:root{--bg:#0a0a0a;--surf:#161616;--surf2:#1f1f1f;--bdr:#272727;--acc:#c8f060;--acc2:#60d4f0;--acc3:#f06090;--txt:#f0ece4;--mut:#686868;--mut2:#343434;--done-bg:#1e2d0a;--done-bdr:#3a5214}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
html,body{height:100%;background:var(--bg);color:var(--txt);font-family:-apple-system,BlinkMacSystemFont,'Helvetica Neue',sans-serif;overflow:hidden}
.app{display:flex;flex-direction:column;height:100vh;height:100dvh}
.topbar{padding:env(safe-area-inset-top,14px) 16px 10px;padding-top:max(env(safe-area-inset-top),14px);background:var(--bg);border-bottom:1px solid var(--bdr);flex-shrink:0}
.topbar-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px}
.app-title{font-size:18px;font-weight:700;letter-spacing:.02em;color:var(--acc)}
.tourney{font-size:11px;color:var(--mut);border:1px solid var(--bdr);border-radius:4px;padding:3px 8px}
.phase-tabs{display:flex;gap:5px}
.ptab{flex:1;padding:8px 4px;border-radius:7px;border:1px solid var(--bdr);font-size:12px;font-weight:600;text-align:center;color:var(--mut);background:transparent;cursor:pointer;transition:all .15s;letter-spacing:.01em}
.ptab.active{background:var(--acc);color:#0a0a0a;border-color:var(--acc)}
.subbar{padding:8px 16px;background:var(--bg);border-bottom:1px solid var(--bdr);flex-shrink:0}
.week-row{display:flex;gap:5px;overflow-x:auto;padding-bottom:7px;scrollbar-width:none}
.week-row::-webkit-scrollbar{display:none}
.wtab{flex-shrink:0;padding:5px 11px;border-radius:5px;border:1px solid var(--bdr);font-size:11px;color:var(--mut);background:transparent;cursor:pointer;white-space:nowrap;transition:all .15s}
.wtab.active{border-color:var(--acc2);color:var(--acc2)}
.day-row{display:flex;gap:5px;overflow-x:auto;margin-top:6px;scrollbar-width:none}
.day-row::-webkit-scrollbar{display:none}
.daybtn{flex-shrink:0;width:42px;height:50px;border-radius:8px;border:1px solid var(--bdr);background:transparent;cursor:pointer;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:2px;transition:all .15s}
.daybtn.active{border-color:var(--acc);background:rgba(200,240,96,.07)}
.daybtn.rest-day{opacity:.3;pointer-events:none}
.daybtn.all-done{border-color:#6ab020}
.day-lbl{font-size:12px;font-weight:600;color:var(--mut)}
.daybtn.active .day-lbl{color:var(--acc)}
.daybtn.all-done .day-lbl{color:#8acc30}
.day-pct{font-size:10px;color:var(--mut)}
.daybtn.all-done .day-pct{color:#8acc30}
.scroll-area{flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch;padding-bottom:40px}
.sess-hdr{padding:14px 16px 10px;border-bottom:1px solid var(--bdr);position:sticky;top:0;background:var(--bg);z-index:5}
.type-pill{display:inline-block;font-size:10px;font-weight:600;padding:2px 8px;border-radius:3px;border:1px solid;margin-bottom:5px;letter-spacing:.04em;text-transform:uppercase}
.sess-title{font-size:22px;font-weight:700;line-height:1.1;letter-spacing:.01em}
.sess-sub{font-size:12px;color:var(--mut);margin-top:3px}
.prog-row{display:flex;align-items:center;gap:10px;margin-top:10px}
.prog-track{flex:1;height:3px;background:var(--mut2);border-radius:2px;overflow:hidden}
.prog-bar{height:100%;border-radius:2px;transition:width .25s ease}
.prog-num{font-size:11px;color:var(--mut);min-width:36px;text-align:right}
.hip-note{margin:10px 16px 0;padding:9px 12px;background:rgba(200,240,96,.05);border:1px solid rgba(200,240,96,.18);border-radius:7px;font-size:12px;color:var(--acc);line-height:1.5}
.section{padding:0 16px}
.sec-hdr{font-size:10px;font-weight:600;letter-spacing:.09em;text-transform:uppercase;color:var(--mut);padding:14px 0 7px;display:flex;align-items:center;gap:8px}
.sec-hdr::after{content:'';flex:1;height:1px;background:var(--bdr)}
.item{display:flex;align-items:flex-start;gap:11px;padding:11px 12px;border-radius:9px;margin-bottom:5px;cursor:pointer;border:1px solid var(--bdr);background:var(--surf);transition:background .1s,border-color .1s}
.item:active{background:var(--surf2)}
.item.ck{background:var(--done-bg);border-color:var(--done-bdr)}
.chkbox{width:22px;height:22px;border-radius:6px;border:1.5px solid var(--mut2);flex-shrink:0;display:flex;align-items:center;justify-content:center;margin-top:1px;font-size:13px;transition:all .18s;color:#0a0a0a}
.item.ck .chkbox{background:var(--acc);border-color:var(--acc)}
.iname{font-size:14px;font-weight:500;line-height:1.3;color:var(--txt)}
.item.ck .iname{text-decoration:line-through;color:var(--mut)}
.idetail{font-size:12px;color:var(--mut);margin-top:2px;line-height:1.4}
.item.ck .idetail{color:var(--mut2)}
.coach{margin:6px 16px 0;padding:11px 13px;background:var(--surf);border-left:2px solid var(--acc2);border-radius:0 7px 7px 0;font-size:12px;color:var(--mut);line-height:1.6}
.coach b{color:var(--txt);font-weight:500}
.done-banner{margin:14px 16px 0;padding:13px;background:rgba(200,240,96,.08);border:1px solid var(--acc);border-radius:9px;text-align:center;font-size:16px;font-weight:700;letter-spacing:.03em;color:var(--acc);display:none}
.rest-screen{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:60px 28px;text-align:center;gap:10px;min-height:300px}
.rest-icon{font-size:44px;margin-bottom:6px}
.rest-title{font-size:26px;font-weight:700;letter-spacing:.01em}
.rest-body{font-size:13px;color:var(--mut);line-height:1.65;max-width:280px}
</style>
</head>
<body>
