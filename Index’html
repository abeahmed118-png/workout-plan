var DLBL=['Mon','Tue','Wed','Thu','Fri','Sat','Sun'];
var pi=0,wi=0,di=0;
var ST={};
try{ST=JSON.parse(localStorage.getItem('hpk')||'{}')}catch(e){}
function save(){try{localStorage.setItem('hpk',JSON.stringify(ST))}catch(e){}}
function K(p,w,d,s,i){return p+'|'+w+'|'+d+'|'+s+'|'+i}
function getPct(p,w,d){
  var day=PH[p].days[d];
  if(day.rest)return 100;
  var tot=HIP.length,dn=0;
  for(var i=0;i<HIP.length;i++)if(ST[K(p,w,d,'h',i)])dn++;
  for(var s=0;s<day.s.length;s++)for(var i=0;i<day.s[s].i.length;i++){tot++;if(ST[K(p,w,d,s,i)])dn++;}
  return tot?Math.round(dn/tot*100):0;
}
function renderPTabs(){
  var h='';
  for(var i=0;i<PH.length;i++)h+='<div class="ptab'+(i===pi?' active':'')+'" onclick="setP('+i+')">'+PH[i].lb+': '+PH[i].fl+'</div>';
  document.getElementById('ptabs').innerHTML=h;
}
function renderWTabs(){
  var ph=PH[pi],h='';
  for(var i=0;i<ph.wks.length;i++)h+='<div class="wtab'+(i===wi?' active':'')+'" onclick="setW('+i+')">'+ph.wks[i]+'</div>';
  document.getElementById('wrow').innerHTML=h;
}
function renderDays(){
  var ph=PH[pi],h='';
  for(var i=0;i<ph.days.length;i++){
    var d=ph.days[i],p=getPct(pi,wi,i);
    var cls='daybtn'+(i===di?' active':'')+(d.rest?' rest-day':'')+((!d.rest&&p===100)?' all-done':'');
    var col=i===di&&!d.rest?'border-color:'+ph.col:'';
    h+='<div class="'+cls+'" onclick="'+(d.rest?'':'setD('+i+')')+'" style="'+col+'">';
    h+='<div class="day-lbl" style="'+(i===di&&!d.rest?'color:'+ph.col:'')+'">'+DLBL[i]+'</div>';
    h+='<div class="day-pct">'+(d.rest?'—':(p>0?p+'%':'·'))+'</div></div>';
  }
  document.getElementById('drow').innerHTML=h;
}
function renderSession(){
  var ph=PH[pi],day=ph.days[di],el=document.getElementById('sarea');
  el.scrollTop=0;
  if(day.rest){
    el.innerHTML='<div class="rest-screen"><div class="rest-icon">'+(day.tourn?'🏒':'😴')+'</div><div class="rest-title">'+(day.tourn?'Tournament Day':'Rest Day')+'</div><div class="rest-body">'+(day.tourn?'May 16, 2026. Everything you\'ve built leads to this. Sleep well, eat well, stay loose. You\'re ready.':'Sleep, eat, recover. Full rest is a required part of this plan — not optional.')+'</div></div>';
    return;
  }
  var p=getPct(pi,wi,di);
  var tot=HIP.length,dn=0;
  for(var i=0;i<HIP.length;i++)if(ST[K(pi,wi,di,'h',i)])dn++;
  for(var s=0;s<day.s.length;s++)for(var ii=0;ii<day.s[s].i.length;ii++){tot++;if(ST[K(pi,wi,di,s,ii)])dn++;}
  var h='<div class="sess-hdr">';
  h+='<div class="type-pill" style="color:'+day.tc+';border-color:'+day.tc+';background:'+day.tc+'18">'+day.ty+'</div>';
  h+='<div class="sess-title">'+day.ti+'</div>';
  h+='<div class="sess-sub">'+day.su+'</div>';
  h+='<div class="prog-row"><div class="prog-track"><div class="prog-bar" id="pb" style="width:'+p+'%;background:'+ph.col+'"></div></div><div class="prog-num" id="pn">'+dn+'/'+tot+'</div></div>';
  h+='</div>';
  h+='<div class="hip-note">⚡ Hip reset first — every morning before training. Your #1 priority.</div>';
  h+='<div class="section"><div class="sec-hdr">Morning Hip Reset</div>';
  for(var i=0;i<HIP.length;i++){
    var k=K(pi,wi,di,'h',i),ck=ST[k]?' ck':'';
    h+='<div class="item'+ck+'" onclick="tog(\''+k+'\')"><div class="chkbox">'+(ST[k]?'✓':'')+'</div><div><div class="iname">'+HIP[i].n+'</div><div class="idetail">'+HIP[i].d+'</div></div></div>';
  }
  h+='</div>';
  for(var s=0;s<day.s.length;s++){
    h+='<div class="section"><div class="sec-hdr">'+day.s[s].h+'</div>';
    for(var ii=0;ii<day.s[s].i.length;ii++){
      var k=K(pi,wi,di,s,ii),ck=ST[k]?' ck':'',it=day.s[s].i[ii];
      h+='<div class="item'+ck+'" onclick="tog(\''+k+'\')"><div class="chkbox">'+(ST[k]?'✓':'')+'</div><div><div class="iname">'+it.n+'</div><div class="idetail">'+it.d+'</div></div></div>';
    }
    h+='</div>';
  }
  if(day.no)h+='<div class="coach"><b>Coach:</b> '+day.no+'</div>';
  h+='<div class="done-banner" id="db" style="display:'+(p===100?'block':'none')+'">Session complete 🏒</div>';
  el.innerHTML=h;
}
function tog(k){
  ST[k]=!ST[k];save();
  var el=document.querySelector('[onclick="tog(\''+k+'\')"]');
  if(el){el.classList.toggle('ck',ST[k]);el.querySelector('.chkbox').textContent=ST[k]?'✓':'';}
  var p=getPct(pi,wi,di);
  var day=PH[pi].days[di];
  var tot=HIP.length,dn=0;
  for(var i=0;i<HIP.length;i++)if(ST[K(pi,wi,di,'h',i)])dn++;
  for(var s=0;s<day.s.length;s++)for(var ii=0;ii<day.s[s].i.length;ii++){tot++;if(ST[K(pi,wi,di,s,ii)])dn++;}
  var pb=document.getElementById('pb');if(pb)pb.style.width=p+'%';
  var pn=document.getElementById('pn');if(pn)pn.textContent=dn+'/'+tot;
  var db=document.getElementById('db');if(db)db.style.display=p===100?'block':'none';
  renderDays();
}
function setP(i){pi=i;wi=0;di=0;renderPTabs();renderWTabs();renderDays();renderSession();}
function setW(i){wi=i;renderWTabs();renderDays();renderSession();}
function setD(i){di=i;renderDays();renderSession();}
(function(){
  var start=new Date('2026-03-16'),now=new Date();
  var diff=Math.floor((now-start)/86400000);
  if(diff>=0&&diff<56){
    var tw=Math.floor(diff/7),dow=diff%7;
    if(tw<3){pi=0;wi=tw;}else if(tw<6){pi=1;wi=tw-3;}else{pi=2;wi=tw-6;}
    di=dow;
  }
})();
renderPTabs();renderWTabs();renderDays();renderSession();
</script>
</body>
